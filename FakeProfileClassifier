# 4) Simple prediction wrapper
# ------------------------
def load_model(path="fake_detector_rf.joblib"):
    d = joblib.load(path)
    return d["pipeline"], d

def predict_account_is_fake(pipeline, account_record):
    """
    account_record: dict with keys matching the training columns except label & user_id.
    Example:
      account = {
        "followers": 120,
        "following": 900,
        "posts_count": 3,
        "account_age_days": 20,
        "bio": "Buy now - great deals at www.deals.com",
        "recent_posts": "Buy now! Click here www.x.com",
        "has_profile_image": 0,
        "uses_default_image": 1,
        "url_in_bio": 1,
        "hashtags_per_post": 3,
        "mentions_per_post": 0,
        "language": "en"
      }
    Returns: dict with probability and prediction (0=real,1=fake)
    """
    # convert to DataFrame expected by pipeline and recompute engineered features
    df = pd.DataFrame([account_record])
    df = add_engineered_features(df)
    pred_proba = pipeline.predict_proba(df)[:,1][0]
    pred_label = int(pred_proba >= 0.5)
    return {"is_fake_prob": float(pred_proba), "is_fake": pred_label}

